@model gestionFilms.Models.Film
@{
    ViewData["Title"] = "Supprimer un film";
}

<h2>Suppression</h2>

<h3 class="text-danger mt-3 mb-4">Êtes-vous sûr de vouloir supprimer ce film ?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">Titre</dt>
        <dd class="col-sm-10">@Model.Titre</dd>

        <dt class="col-sm-2">Genre</dt>
        <dd class="col-sm-10">@Model.Genre</dd>

        <dt class="col-sm-2">Année de sortie</dt>
        <dd class="col-sm-10">@Model.Annee</dd>
    </dl>
    
    <form asp-action="Supprimer" method="post" class="mt-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Supprimer</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Retour à la liste</a>
    </form>
</div>
